<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Voice Access\nSettings"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/claude_on_surface"
            android:padding="24dp" />

        <!-- Help section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Help"
            android:textColor="@color/claude_primary"
            android:textSize="15sp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="16dp" />

        <!-- Voice Access Commands -->
        <LinearLayout
            android:id="@+id/btn_voice_commands"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Voice Access commands"
                android:textColor="@color/claude_on_surface"
                android:textSize="16sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="List of commands sorted by category"
                android:textColor="@color/claude_on_surface_variant"
                android:textSize="14sp" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/claude_divider" android:layout_marginStart="24dp" />

        <!-- Help and Feedback -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Help and feedback"
                android:textColor="@color/claude_on_surface"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/claude_divider" android:layout_marginStart="24dp" />

        <!-- Open Tutorial -->
        <LinearLayout
            android:id="@+id/btn_open_tutorial"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Open tutorial"
                android:textColor="@color/claude_on_surface"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/claude_divider" />

        <!-- Voice command preferences section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Voice command preferences"
            android:textColor="@color/claude_primary"
            android:textSize="13sp"
            android:paddingStart="24dp"
            android:paddingTop="16dp"
            android:paddingBottom="4dp" />

        <!-- Require verbs -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="24dp"
            android:gravity="center_vertical">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Require verbs"
                    android:textColor="@color/claude_on_surface"
                    android:textSize="16sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Require verbs (e.g., tap or open) for Voice Access commands"
                    android:textColor="@color/claude_on_surface_variant"
                    android:textSize="14sp" />
            </LinearLayout>
            <Switch
                android:id="@+id/switch_require_verbs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/claude_divider" android:layout_marginStart="24dp" />

        <!-- Timeout after no speech -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="24dp"
            android:gravity="center_vertical">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Time out after no speech"
                    android:textColor="@color/claude_on_surface"
                    android:textSize="16sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Stop Voice Access after 30 seconds if no speech is detected"
                    android:textColor="@color/claude_on_surface_variant"
                    android:textSize="14sp" />
            </LinearLayout>
            <Switch
                android:id="@+id/switch_timeout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/claude_divider" />

        <!-- Activation section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Activation"
            android:textColor="@color/claude_primary"
            android:textSize="13sp"
            android:paddingStart="24dp"
            android:paddingTop="16dp"
            android:paddingBottom="4dp" />

        <!-- Listening behavior -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Listening behavior on screen wake up"
                android:textColor="@color/claude_on_surface"
                android:textSize="16sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/text_listening_behavior"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Always start listening"
                android:textColor="@color/claude_on_surface_variant"
                android:textSize="14sp" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/claude_divider" android:layout_marginStart="24dp" />

        <!-- Activate for incoming calls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="24dp"
            android:gravity="center_vertical">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Activate for incoming calls"
                    android:textColor="@color/claude_on_surface"
                    android:textSize="16sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Turn on Voice Access when you get a phone call"
                    android:textColor="@color/claude_on_surface_variant"
                    android:textSize="14sp" />
            </LinearLayout>
            <Switch
                android:id="@+id/switch_activate_calls"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/claude_divider" android:layout_marginStart="24dp" />

        <!-- Active during calls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="24dp"
            android:gravity="center_vertical">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Active during calls"
                    android:textColor="@color/claude_on_surface"
                    android:textSize="16sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Keep Voice Access on during phone calls"
                    android:textColor="@color/claude_on_surface_variant"
                    android:textSize="14sp" />
            </LinearLayout>
            <Switch
                android:id="@+id/switch_during_calls"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/claude_divider" />

        <!-- Setup section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Setup"
            android:textColor="@color/claude_primary"
            android:textSize="13sp"
            android:paddingStart="24dp"
            android:paddingTop="16dp"
            android:paddingBottom="4dp" />

        <!-- Set up Voice Access -->
        <LinearLayout
            android:id="@+id/btn_setup_voice_access"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Set up Voice Access"
                android:textColor="@color/claude_on_surface"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/claude_divider" android:layout_marginStart="24dp" />

        <!-- Configure activation key -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Configure activation key"
                android:textColor="@color/claude_on_surface"
                android:textSize="16sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Configure a physical key/switch to control starting and stopping of Voice Access"
                android:textColor="@color/claude_on_surface_variant"
                android:textSize="14sp" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/claude_divider" android:layout_marginStart="24dp" />

        <!-- Recognize common icons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="24dp"
            android:gravity="center_vertical">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Recognize common icons"
                    android:textColor="@color/claude_on_surface"
                    android:textSize="16sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Detect the names of common icons, may use additional CPU and battery."
                    android:textColor="@color/claude_on_surface_variant"
                    android:textSize="14sp" />
            </LinearLayout>
            <Switch
                android:id="@+id/switch_recognize_icons"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Privacy Policy -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Privacy policy"
            android:textColor="@color/claude_primary"
            android:textSize="14sp"
            android:paddingStart="24dp"
            android:paddingTop="16dp"
            android:paddingBottom="32dp" />

    </LinearLayout>
</ScrollView>

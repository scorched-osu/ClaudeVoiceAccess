<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ClaudeVoiceAccess" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/claude_primary</item>
        <item name="colorPrimaryDark">@color/claude_primary_dark</item>
        <item name="colorAccent">@color/claude_accent</item>
        <item name="android:windowBackground">@color/claude_background</item>
        <item name="android:statusBarColor">@color/claude_primary_dark</item>
    </style>

    <style name="Theme.ClaudeVoiceAccess.NoActionBar" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/claude_primary</item>
        <item name="colorPrimaryDark">@color/claude_primary_dark</item>
        <item name="colorAccent">@color/claude_accent</item>
        <item name="android:windowBackground">@color/claude_background</item>
    </style>

    <style name="SectionHeader">
        <item name="android:textColor">@color/section_header</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">8dp</item>
        <item name="android:paddingStart">16dp</item>
    </style>

    <style name="CommandItem.Title">
        <item name="android:textColor">@color/claude_on_surface</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="CommandItem.Desc">
        <item name="android:textColor">@color/claude_on_surface_variant</item>
        <item name="android:textSize">14sp</item>
    </style>
</resources>
